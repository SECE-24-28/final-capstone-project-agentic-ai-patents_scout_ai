# =============================================================================
# PatentScout AI — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Environment Variables & API Keys (NEVER commit secrets)
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.key
*.pem
secrets/

# -----------------------------------------------------------------------------
# Python Virtual Environment (uv / venv)
# -----------------------------------------------------------------------------
.venv/
venv/
ENV/
env/
.python-version

# -----------------------------------------------------------------------------
# Python Bytecode & Caches
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
.cache/

# -----------------------------------------------------------------------------
# Testing & Coverage
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
coverage.xml
htmlcov/
*.lcov
.tox/
.nox/

# -----------------------------------------------------------------------------
# ChromaDB — Persistent Vector Database (local runtime artefact)
# -----------------------------------------------------------------------------
backend/chroma_db/
chroma_db/
*.sqlite3

# -----------------------------------------------------------------------------
# Data Directories — Raw & Processed Downloads
# -----------------------------------------------------------------------------
data/raw_patents/
data/processed_patents/
data/*.csv
data/*.json
data/*.parquet

# -----------------------------------------------------------------------------
# Backend Raw Response Test Fixtures (large auto-generated JSON)
# -----------------------------------------------------------------------------
backend/tests/google_patents_raw_response.json

# -----------------------------------------------------------------------------
# Jupyter Notebooks — Checkpoints & Outputs
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# Build & Distribution Artefacts
# -----------------------------------------------------------------------------
dist/
build/
*.egg-info/
*.egg
MANIFEST
site/
.eggs/

# -----------------------------------------------------------------------------
# uv / pip Lock & Cache (lock file is intentionally committed; cache is not)
# -----------------------------------------------------------------------------
.uv/
pip-wheel-metadata/
*.whl

# -----------------------------------------------------------------------------
# Type-checking & Linting
# -----------------------------------------------------------------------------
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json
pyrightconfig.json

# -----------------------------------------------------------------------------
# IDEs & Editors
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.spyproject/

# -----------------------------------------------------------------------------
# macOS System Files
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride

# -----------------------------------------------------------------------------
# Windows System Files
# -----------------------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# Docker & Container Volumes
# -----------------------------------------------------------------------------
postgres_data/
docker/volumes/

# -----------------------------------------------------------------------------
# Logs & Temporary Files
# -----------------------------------------------------------------------------
*.log
*.tmp
*.bak
*.orig
logs/
tmp/

# -----------------------------------------------------------------------------
# Reports & Generated Outputs (runtime artefacts)
# -----------------------------------------------------------------------------
reports/
output/
*.pdf
*.docx

# -----------------------------------------------------------------------------
# Node / Frontend (reserved for future React/Vite dashboard)
# -----------------------------------------------------------------------------
frontend/node_modules/
frontend/.next/
frontend/dist/
frontend/.env
frontend/.env.local

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
past_conversation_transcript.md
implementation_plan.md
task.md
